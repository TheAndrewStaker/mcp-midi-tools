{
  "name": "mcp-midi-control",
  "version": "0.1.0",
  "description": "Talk to Claude, control your MIDI gear. Local MCP server with first-class Fractal AM4 support.",
  "private": true,
  "license": "Apache-2.0",
  "author": "Stephen Staker <stephenstaker@gmail.com>",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "probe": "tsx scripts/_research/probe.ts",
    "read-probe": "tsx scripts/_research/read-probe.ts",
    "sanity-probe": "tsx scripts/_research/sanity-probe.ts",
    "state-probe": "tsx scripts/_research/state-probe.ts",
    "channel-probe": "tsx scripts/_research/channel-probe.ts",
    "probe-amp-knobs": "tsx scripts/probe-amp-knob-applicability.ts",
    "launch-verify": "tsx scripts/launch-verification.ts",
    "sniff": "tsx scripts/_research/sniff.ts",
    "diff-syx": "tsx scripts/_research/diff-syx.ts",
    "scrape-wiki": "tsx scripts/scrape-wiki.ts",
    "extract-lineage": "tsx scripts/extract-lineage.ts",
    "extract-factory-data": "tsx scripts/extract-factory-data.ts",
    "extract-axe-fx-ii-catalog": "tsx scripts/extract-axe-fx-ii-catalog.ts",
    "extract-axe-fx-ii-params": "tsx scripts/extract-axe-fx-ii-params.ts",
    "extract-axe-fx-ii-lineage": "tsx scripts/extract-axe-fx-ii-lineage.ts",
    "check-axefx2-capture": "tsx scripts/check-axefx2-capture.ts",
    "capture-midi": "tsx scripts/capture-midi-passive.ts",
    "capture-axefx2": "tsx scripts/capture-midi-passive.ts axe-fx",
    "capture-am4": "tsx scripts/capture-midi-passive.ts am4",
    "regen": "npm run extract-lineage && npm run extract-axe-fx-ii-params && npm run extract-axe-fx-ii-lineage",
    "verify-axe-fx-ii-encoding": "tsx scripts/verify-axe-fx-ii-encoding.ts",
    "verify-axe-fx-iii-encoding": "tsx scripts/verify-axe-fx-iii-encoding.ts",
    "verify-axe-fx-ii-param-lookup": "tsx scripts/verify-axe-fx-ii-param-lookup.ts",
    "verify-axe-fx-ii-lineage": "tsx scripts/verify-axe-fx-ii-lineage.ts",
    "verify-axe-fx-ii-routing": "tsx scripts/verify-axe-fx-ii-routing.ts",
    "verify-dispatcher": "tsx scripts/verify-dispatcher.ts",
    "build-type-knobs": "tsx scripts/build-type-knobs.ts",
    "verify-pack": "tsx scripts/verify-pack.ts",
    "verify-sysex-assembler": "tsx scripts/verify-sysex-assembler.ts",
    "verify-msg": "tsx scripts/verify-msg.ts",
    "verify-describe-inbound": "tsx scripts/verify-describe-inbound.ts",
    "verify-transpile": "tsx scripts/verify-transpile.ts",
    "verify-enum-lookup": "tsx scripts/verify-enum-lookup.ts",
    "verify-echo": "tsx scripts/verify-echo.ts",
    "verify-cache-params": "tsx scripts/verify-cache-params.ts",
    "verify-preset-dump": "tsx scripts/verify-preset-dump.ts",
    "verify-safety": "tsx scripts/verify-safety.ts",
    "gen-params": "tsx scripts/gen-params-from-cache.ts",
    "smoke-server": "tsx scripts/smoke-server.ts",
    "verify-lineage-resources": "tsx scripts/verify-lineage-resources.ts",
    "coverage-audit": "tsx scripts/coverage-audit.ts",
    "coverage-cross-ref-audit": "tsx scripts/_research/coverage-cross-ref-audit.ts",
    "write-test": "tsx scripts/_research/write-test.ts",
    "server": "tsx packages/server-all/src/server/index.ts",
    "build:core": "npm run build --workspace=@mcp-midi-control/core",
    "build:am4": "npm run build --workspace=@mcp-midi-control/am4",
    "build:axe-fx-ii": "npm run build --workspace=@mcp-midi-control/axe-fx-ii",
    "build:axe-fx-iii": "npm run build --workspace=@mcp-midi-control/axe-fx-iii",
    "build:hydrasynth-explorer": "npm run build --workspace=@mcp-midi-control/hydrasynth-explorer",
    "build:server-all": "npm run build --workspace=@mcp-midi-control/server-all",
    "build": "npm run build:core && npm run build:am4 && npm run build:axe-fx-ii && npm run build:axe-fx-iii && npm run build:hydrasynth-explorer && npm run build:server-all && tsx scripts/copy-build-assets.ts",
    "inspect": "npx @modelcontextprotocol/inspector node packages/server-all/dist/server/index.js",
    "agent-sweep": "tsx scripts/agent-regression/index.ts",
    "agent-sweep:am4": "tsx scripts/agent-regression/index.ts --device=am4",
    "agent-sweep:real": "tsx scripts/agent-regression/index.ts --real-hardware",
    "agent-sweep:am4:real": "tsx scripts/agent-regression/index.ts --device=am4 --real-hardware",
    "mcp-test-apply": "tsx scripts/mcp-test-apply-preset.ts",
    "mcp-test-suite": "tsx scripts/mcp-test-preset-suite.ts",
    "mcp-test-safe-edit": "tsx scripts/mcp-test-safe-edit-scenarios.ts",
    "build:installer": "tsx scripts/build-installer.ts",
    "setup-claude-desktop": "npm run build && tsx scripts/setup-claude-desktop.ts",
    "hydra:smoke": "tsx scripts/hydrasynth/smoke.ts",
    "hydra:server": "tsx packages/hydrasynth-explorer/src/server.ts",
    "hydra:gen-params": "tsx scripts/hydrasynth/gen-params.ts",
    "hydra:gen-nrpn": "tsx scripts/hydrasynth/gen-nrpn.ts",
    "hydra:gen-enums": "tsx scripts/hydrasynth/gen-enums.ts",
    "hydra:bake-init-patch": "tsx scripts/hydrasynth/bake-init-patch.ts",
    "hydra:verify-encoding": "tsx scripts/hydrasynth/verify-encoding.ts",
    "hydra:verify-sysex-envelope": "tsx scripts/hydrasynth/verify-sysex-envelope.ts",
    "hydra:verify-sysex-patch": "tsx scripts/hydrasynth/verify-sysex-patch.ts",
    "hydra:verify-init-buffer": "tsx scripts/hydrasynth/verify-init-buffer.ts",
    "hydra:test-patch-name": "tsx scripts/hydrasynth/test-patch-name.ts",
    "hydra:verify-enum-mapping": "tsx scripts/hydrasynth/verify-enum-mapping.ts",
    "hydra:verify-nrpn-display": "tsx scripts/hydrasynth/verify-nrpn-display.ts",
    "test": "npm run verify-pack && npm run verify-sysex-assembler && npm run verify-msg && npm run verify-describe-inbound && npm run verify-transpile && npm run verify-enum-lookup && npm run verify-echo && npm run verify-cache-params && npm run verify-preset-dump && npm run verify-safety && npm run verify-axe-fx-ii-encoding && npm run verify-axe-fx-ii-param-lookup && npm run verify-axe-fx-ii-lineage && npm run verify-axe-fx-ii-routing && npm run verify-axe-fx-iii-encoding && npm run verify-dispatcher && npm run hydra:verify-encoding && npm run hydra:verify-sysex-envelope && npm run hydra:verify-sysex-patch && npm run hydra:verify-init-buffer && npm run hydra:test-patch-name && npm run hydra:verify-enum-mapping && npm run hydra:verify-nrpn-display && npm run smoke-server && npm run build && npm run verify-lineage-resources",
    "test:jest": "jest --testPathIgnorePatterns=integration",
    "test:jest:all": "jest",
    "typecheck": "tsc --noEmit -p packages/core/tsconfig.json && tsc --noEmit -p packages/am4/tsconfig.json && tsc --noEmit -p packages/axe-fx-ii/tsconfig.json && tsc --noEmit -p packages/axe-fx-iii/tsconfig.json && tsc --noEmit -p packages/hydrasynth-explorer/tsconfig.json && tsc --noEmit -p packages/server-all/tsconfig.json",
    "preflight": "npm run typecheck && npm test && npm run coverage-audit && npm run coverage-cross-ref-audit",
    "release-gate": "npm run preflight && npm run launch-verify && npm run agent-sweep"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@types/adm-zip": "^0.5.8",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "adm-zip": "^0.5.17",
    "fractal-midi": "0.1.0-alpha.0",
    "jest": "^29.0.0",
    "midi": "^2.0.0",
    "ts-jest": "^29.0.0",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.19.0",
    "typescript": "^5.0.0",
    "zod": "^4.4.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
